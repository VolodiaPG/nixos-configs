{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "model": "ollama/gemma4",
  "plugin": [
    "@simonwjackson/opencode-direnv@latest",
    "@tarquinen/opencode-dcp@latest",
    "oh-my-opencode-slim@latest"
  ],
  "provider": {
    "ollama": {
      "models": {
        "gemma4": {
          "_launch": true,
          "name": "gemma4:e4b"
        },
        "qwen3.5": {
          "_launch": true,
          "name": "qwen3.5:9b"
        }
      },
      "name": "Ollama",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:11434/v1"
      }
    }
  }
}
