# Additional settings
set database sqlite
set sandbox normal
set page-padding 2
set show-recent 20
set first-page-column 1

set adjust-open	"best-fit"
set completion-bg	"#1a1f2e"
set completion-fg	"#e6e1cf"
set completion-highlight-bg	"#00d4ff80"
set completion-highlight-fg	"#0a0e1a"
set default-bg	"#0a0e1a"
set default-fg	"#e6e1cf"
set guioptions	"shv"
set highlight-active-color	"#00d4ff80"
set highlight-color	"#39ff1480"
set incremental-search	"true"
set inputbar-bg	"#1a1f2e"
set inputbar-fg	"#e6e1cf"
set nohlsearch	"false"
set notification-bg	"#1a1f2e"
set notification-error-bg	"#ff004080"
set notification-error-fg	"#0a0e1a"
set notification-fg	"#e6e1cf"
set notification-warning-bg	"#ff660080"
set notification-warning-fg	"#0a0e1a"
set page-cache-size	"50"
set page-padding	"5"
set pages-per-row	"1"
set recolor	"true"
set recolor-darkcolor	"#e6e1cf"
set recolor-keephue	"true"
set recolor-lightcolor	"#0a0e1a"
set render-loading	"true"
set render-loading-bg	"#0a0e1a"
set render-loading-fg	"#e6e1cf"
set scroll-full-overlap	"0.01"
set scroll-page-aware	"true"
set scroll-step	"100"
set selection-clipboard	"clipboard"
set selection-notification	"true"
set smooth-scroll	"true"
set statusbar-basename	"true"
set statusbar-bg	"#1a1f2e"
set statusbar-fg	"#e6e1cf"
set statusbar-home-tilde	"true"
set synctex	"true"
set window-title-basename	"true"
set window-title-home-tilde	"true"
set zoom-max	"1000"
set zoom-min	"10"
set zoom-step	"20"
map [normal] +   zoom in
map [normal] -   zoom out
map [normal] <Tab>   toggle_index
map [normal] =   zoom in
map [normal] G   goto bottom
map [normal] H   scroll half-left
map [normal] J   scroll half-down
map [normal] K   scroll half-up
map [normal] L   scroll half-right
map [normal] N   search backward
map [normal] R   reload
map [normal] f   toggle_fullscreen
map [normal] gg   goto top
map [normal] n   search forward
map [normal] q   quit
map [normal] r   recolor
map [normal] s   toggle_statusbar
